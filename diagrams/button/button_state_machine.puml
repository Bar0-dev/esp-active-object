@startuml

[*] --> RELEASED : currentState = high
[*] --> PRESSED : currentState = low


RELEASED --> PRESSED : BUTTON_STATE_CHANGED_SIG
RELEASED : e/publish EV_BUTTON_RELEASED 

PRESSED --> PRE_DOUBLE_PRESSED : BUTTON_STATE_CHANGED_SIG
PRESSED --> HOLD : BUTTON_HOLD_SIG
PRESSED : e/arm hold timer
PRESSED : e/publish EV_BUTTON_PRESSED

HOLD --> RELEASED : BUTTON_STATE_CHANGED_SIG 
HOLD : e/pulish EV_BUTTON_HOLD

PRE_DOUBLE_PRESSED --> RELEASED : BUTTON_DOUBLE_PRESS_SIG
PRE_DOUBLE_PRESSED --> DOUBLE_PRESSED : BUTTON_STATE_CHANGED_SIG
PRE_DOUBLE_PRESSED : e/disarm hold timer
PRE_DOUBLE_PRESSED : e/arm doule press timer

DOUBLE_PRESSED --> RELEASED : BUTTON_STATE_CHANGED_SIG
DOUBLE_PRESSED : e/disarm double press timer
DOUBLE_PRESSED : e/publish EV_BUTTON_DOUBLE_PRESS

@endum